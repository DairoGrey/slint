import { MaterialPalette } from "styling.slint";

component ScrollBar inherits Rectangle {
    in-out property <bool> horizontal;
    in-out property <length> maximum;
    in-out property <length> page-size;
    // this is always negative and bigger than  -maximum
    in-out property <length> value;
    in-out property <bool> enabled <=> touch-area.enabled;
    in property <ScrollBarPolicy> policy: ScrollBarPolicy.as-needed;
    in property <brush> track-color: #00000000;
    in property <brush> track-hover-color: #00000000;
    in property <brush> thumb-color: MaterialPalette.border;
    in property <brush> thumb-hover-color: MaterialPalette.border;
    in property <brush> thumb-pressed-color: MaterialPalette.border;
    in property <length> thumb-min-size: 32px;
    in property <length> thumb-padding: 0px;
    in property <length> radius: 4px;

    callback scrolled();

    states [
        disabled when !touch-area.enabled : {
            background.border-color: MaterialPalette.control-foreground;
            handle.opacity: 0.12;
        }
    ]

    visible: (self.policy == ScrollBarPolicy.always-on) || (self.policy == ScrollBarPolicy.as-needed && self.maximum > 0);
    clip: true;
    background: root.track-color;

    state-layer := Rectangle {
        width: 100%;
        height: 100%;
        background: root.track-hover-color;
        border-radius: root.radius;
        opacity: !root.enabled ? 0 : (touch-area.pressed ? 1 : (touch-area.has-hover ? 1 : 0));
        visible: handle.width > 0 && handle.height > 0;

        animate opacity { duration: 250ms; easing: ease; }
    }

    handle := Rectangle {
        x: !root.horizontal ? root.thumb-padding : (root.width - handle.width) * (-root.value / root.maximum);
        y: root.horizontal ? root.thumb-padding : (root.height - handle.height) * (-root.value / root.maximum);
        width: !root.horizontal ? max(0px, parent.width - 2 * root.thumb-padding) : root.maximum <= 0phx ? 0phx : max(min(root.thumb-min-size, root.width), parent.width * max(root.page-size / (root.maximum + root.page-size)));
        height: root.horizontal ? max(0px, parent.height - 2 * root.thumb-padding) : root.maximum <= 0phx ? 0phx : max(min(root.thumb-min-size, root.height), parent.height * (root.page-size / (root.maximum + root.page-size)));

        background := Rectangle {
            width: 100%;
            height: 100%;
            border-radius: root.radius;
            background: !root.enabled ? root.thumb-color
                : (touch-area.pressed ? root.thumb-pressed-color
                : (touch-area.has-hover ? root.thumb-hover-color : root.thumb-color));
        }
    }

    touch-area := TouchArea {
        property <{pressed-value: length, maximum: length, x:length, y: length}> saved-values;

        width: parent.width;
        height: parent.height;

        function update-saved-values() {
            self.saved-values = { pressed-value: -root.value, maximum: root.maximum, x: self.mouse-x, y: self.mouse-y };
        }

        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                self.update-saved-values();
            }
        }

        moved => {
            if (self.enabled && self.pressed) {
                // Update reference points when the size of the viewport changes to
                // avoid 'jumping' during scrolling.
                // This happens when height estimate of a ListView changes after
                // new items are loaded.
                if (self.saved-values.maximum != root.maximum) {
                    self.update-saved-values();
                }

                root.value = -max(0px, min(root.maximum, self.saved-values.pressed-value + (
                    root.horizontal ? (self.mouse-x - self.saved-values.x) * (root.maximum / (root.width - handle.width))
                               : (self.mouse-y - self.saved-values.y) * (root.maximum / (root.height - handle.height))
                )));
                root.scrolled();
            }
        }

        scroll-event(event) => {
            if (root.horizontal && event.delta-x != 0) {
                root.value = max(-root.maximum, min(0px, root.value + event.delta-x));
                return accept;
            } else if (!root.horizontal && event.delta-y != 0) {
                root.value = max(-root.maximum, min(0px, root.value + event.delta-y));
                return accept;
            }
            reject
        }
    }
}

// Scrollview contains a viewport that is bigger than the view and can be scrolled.
export component ScrollView {
    in property <bool> enabled: true;
    out property <length> visible-width <=> flickable.width;
    out property <length> visible-height <=> flickable.height;
    in-out property <bool> has-focus;
    in-out property <length> viewport-width <=> flickable.viewport-width;
    in-out property <length> viewport-height <=> flickable.viewport-height;
    in-out property <length> viewport-x <=> flickable.viewport-x;
    in-out property <length> viewport-y <=> flickable.viewport-y;
    in property <ScrollBarPolicy> vertical-scrollbar-policy <=> vertical-bar.policy;
    in property <ScrollBarPolicy> horizontal-scrollbar-policy <=> horizontal-bar.policy;
    in property <bool> mouse-drag-pan-enabled <=> flickable.mouse-drag-pan-enabled;
    // Public scrollbar styling surface. Values are intentionally shared by
    // both axes so applications can style a ScrollView as one control.
    in property <brush> scrollbar-track-color: #00000000;
    in property <brush> scrollbar-track-hover-color: #00000000;
    in property <brush> scrollbar-thumb-color: MaterialPalette.border;
    in property <brush> scrollbar-thumb-hover-color: MaterialPalette.border;
    in property <brush> scrollbar-thumb-pressed-color: MaterialPalette.border;
    in property <length> scrollbar-size: 8px;
    in property <length> scrollbar-thumb-min-size: 32px;
    in property <length> scrollbar-thumb-padding: 0px;
    in property <length> scrollbar-radius: 4px;

    callback scrolled <=> flickable.flicked;

    min-height: 50px;
    min-width: 50px;
    horizontal-stretch: 1;
    vertical-stretch: 1;
    preferred-height: 100%;
    preferred-width: 100%;

    flickable := Flickable {
        x: 0;
        y: 0;
        mouse-drag-pan-enabled: false;
        viewport-y <=> vertical-bar.value;
        viewport-x <=> horizontal-bar.value;
        width: parent.width - vertical-bar.width - 4px;
        height: parent.height - horizontal-bar.height - 4px;

        @children
    }

    vertical-bar := ScrollBar {
        width: root.scrollbar-size;
        x: flickable.width + flickable.x;
        y: flickable.y;
        height: flickable.height;
        horizontal: false;
        maximum: flickable.viewport-height - flickable.height;
        page-size: flickable.height;
        enabled: root.enabled;
        track-color: root.scrollbar-track-color;
        track-hover-color: root.scrollbar-track-hover-color;
        thumb-color: root.scrollbar-thumb-color;
        thumb-hover-color: root.scrollbar-thumb-hover-color;
        thumb-pressed-color: root.scrollbar-thumb-pressed-color;
        thumb-min-size: root.scrollbar-thumb-min-size;
        thumb-padding: root.scrollbar-thumb-padding;
        radius: root.scrollbar-radius;

        scrolled => {root.scrolled()}
    }

    horizontal-bar := ScrollBar {
        height: root.scrollbar-size;
        y: flickable.height + flickable.y;
        x: flickable.x;
        width: flickable.width;
        horizontal: true;
        maximum: flickable.viewport-width - flickable.width;
        page-size: flickable.width;
        enabled: root.enabled;
        track-color: root.scrollbar-track-color;
        track-hover-color: root.scrollbar-track-hover-color;
        thumb-color: root.scrollbar-thumb-color;
        thumb-hover-color: root.scrollbar-thumb-hover-color;
        thumb-pressed-color: root.scrollbar-thumb-pressed-color;
        thumb-min-size: root.scrollbar-thumb-min-size;
        thumb-padding: root.scrollbar-thumb-padding;
        radius: root.scrollbar-radius;

        scrolled => {root.scrolled()}
    }
}
