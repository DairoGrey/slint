export component TestCase inherits Window {
    width: 240phx;
    height: 100phx;

    in-out property <bool> input-enabled: true;
    in-out property <string> surrounding-text: "hello";
    in-out property <int> cursor-offset: 5;
    in-out property <int> anchor-offset: 5;
    in-out property <string> preedit-text: "";
    in-out property <length> caret-x: 8px;
    in-out property <length> caret-y: 12px;
    in-out property <length> caret-width: 0px;
    in-out property <length> caret-height: 0px;
    in-out property <int> input-generation: 1;
    in-out property <string> clipboard-text: "";
    in-out property <int> clipboard-generation: -1;

    out property <bool> input-focused: input.has-focus;
    out property <int> event-generation: input.event-input-generation;
    out property <int> clipboard-acked-generation: input.clipboard-written-generation;
    out property <int> preedit-count: 0;
    out property <int> commit-count: 0;
    out property <int> cancel-count: 0;
    out property <int> clipboard-ack-count: 0;
    out property <string> inserted-text: "";

    input := OverlayTextInputItem {
        x: 0px;
        y: 0px;
        width: 160px;
        height: parent.height;
        enabled: root.input-enabled;
        surrounding-text: root.surrounding-text;
        cursor-offset: root.cursor-offset;
        anchor-offset: root.anchor-offset;
        preedit-text: root.preedit-text;
        caret-x: root.caret-x;
        caret-y: root.caret-y;
        caret-width: root.caret-width;
        caret-height: root.caret-height;
        input-generation: root.input-generation;
        clipboard-write-text: root.clipboard-text;
        clipboard-write-generation: root.clipboard-generation;

        key-pressed(event) => { reject }
        text-input(text) => { root.inserted-text += text; }
        preedit-updated(text) => {
            root.preedit-text = text;
            root.preedit-count += 1;
        }
        composition-committed(text) => {
            root.preedit-text = "";
            root.commit-count += 1;
        }
        composition-cancelled => {
            root.preedit-text = "";
            root.cancel-count += 1;
        }
        clipboard-written => { root.clipboard-ack-count += 1; }
    }

    other := FocusScope {
        x: 180px;
        y: 0px;
        width: 60px;
        height: parent.height;
    }
}

/*
```rust
use i_slint_core::input::{InternalKeyEvent, KeyEventType};
use i_slint_core::items::KeyEvent;
use i_slint_core::platform::Clipboard;
use i_slint_core::window::{InputMethodRequest, WindowInner};
use slint::platform::Key;

let instance = TestCase::new().unwrap();
let take_requests = || {
    slint_testing::access_testing_window(instance.window(), |window| window.ime_requests.take())
};

slint_testing::send_mouse_click(&instance, 40., 40.);
assert!(instance.get_input_focused());
let requests = take_requests();
assert_eq!(requests.len(), 1);
match &requests[0] {
    InputMethodRequest::Enable(props) => {
        assert_eq!(props.text.as_str(), "hello");
        assert_eq!(props.cursor_position, 5);
        assert_eq!(props.anchor_position, None);
        assert_eq!(props.cursor_rect_origin.x, 8.);
        assert_eq!(props.cursor_rect_origin.y, 12.);
        assert_eq!(props.cursor_rect_size.width, 1.);
        assert_eq!(props.cursor_rect_size.height, 1.);
        assert!(props.clip_rect.is_some());
    }
    request => panic!("expected one Enable request, got {request:?}"),
}

// An unchanged render must not generate the old redundant Update.
slint_testing::mock_elapsed_time(1);
assert!(take_requests().is_empty());

instance.set_surrounding_text("hello world".into());
instance.set_cursor_offset(7);
instance.set_anchor_offset(2);
instance.set_input_generation(2);
slint_testing::mock_elapsed_time(1);
let requests = take_requests();
assert_eq!(requests.len(), 1);
assert!(matches!(&requests[0], InputMethodRequest::Update(props)
    if props.text.as_str() == "hello world"
        && props.cursor_position == 7
        && props.anchor_position == Some(2)));

// Candidate geometry alone is ignored without active preedit.
instance.set_caret_y(24.);
slint_testing::mock_elapsed_time(1);
assert!(take_requests().is_empty());

let inner = WindowInner::from_pub(instance.window());
inner.process_key_input(InternalKeyEvent {
    event_type: KeyEventType::UpdateComposition,
    preedit_text: "compose".into(),
    preedit_selection: Some(1..4),
    ..Default::default()
});
assert_eq!(instance.get_preedit_count(), 1);
assert_eq!(instance.get_event_generation(), 2);
slint_testing::mock_elapsed_time(1);
let requests = take_requests();
assert_eq!(requests.len(), 1);
assert!(matches!(&requests[0], InputMethodRequest::Update(props)
    if props.preedit_text.as_str() == "compose"));
instance.set_caret_y(36.);
slint_testing::mock_elapsed_time(1);
let requests = take_requests();
assert_eq!(requests.len(), 1);
assert!(matches!(&requests[0], InputMethodRequest::Update(props)
    if props.preedit_text.as_str() == "compose" && props.cursor_rect_origin.y == 36.));

// A new generation becomes eligible only after its Update is submitted. The
// core item unit test covers an event injected while the generations differ;
// the testing backend flushes pending change handlers before dispatching input.
instance.set_input_generation(3);
slint_testing::mock_elapsed_time(1);
assert!(matches!(take_requests().as_slice(), [InputMethodRequest::Update(_)]));
inner.process_key_input(InternalKeyEvent {
    event_type: KeyEventType::UpdateComposition,
    preedit_text: "current".into(),
    ..Default::default()
});
assert_eq!(instance.get_preedit_count(), 2);
assert_eq!(instance.get_event_generation(), 3);

// AltGr inserts its produced character exactly once.
slint_testing::send_keyboard_char(&instance, Key::AltGr.into(), true);
slint_testing::send_keyboard_char(&instance, '€', true);
slint_testing::send_keyboard_char(&instance, '€', false);
slint_testing::send_keyboard_char(&instance, Key::AltGr.into(), false);
assert_eq!(instance.get_inserted_text().as_str(), "€");

// Common language-switch sequences and Ctrl+Space are never text input.
slint_testing::send_key_combo(&instance, [Key::Meta, Key::Space]);
slint_testing::send_key_combo(&instance, [Key::Alt, Key::Shift]);
slint_testing::send_key_combo(&instance, [Key::Control, Key::Space]);
assert_eq!(instance.get_inserted_text().as_str(), "€");

instance.set_clipboard_text("first".into());
instance.set_clipboard_generation(4);
slint_testing::mock_elapsed_time(1);
assert_eq!(instance.get_clipboard_ack_count(), 1);
assert_eq!(instance.get_clipboard_acked_generation(), 4);
assert_eq!(inner.context().platform().clipboard_text(Clipboard::DefaultClipboard).as_deref(), Some("first"));

// Repeated and older generations do not publish or acknowledge again.
instance.set_clipboard_text("stale".into());
instance.set_clipboard_generation(3);
slint_testing::mock_elapsed_time(1);
assert_eq!(instance.get_clipboard_ack_count(), 1);
assert_eq!(inner.context().platform().clipboard_text(Clipboard::DefaultClipboard).as_deref(), Some("first"));
instance.set_clipboard_text("latest".into());
instance.set_clipboard_generation(5);
slint_testing::mock_elapsed_time(1);
assert_eq!(instance.get_clipboard_ack_count(), 2);
assert_eq!(instance.get_clipboard_acked_generation(), 5);
assert_eq!(inner.context().platform().clipboard_text(Clipboard::DefaultClipboard).as_deref(), Some("latest"));

// Focus loss cancels composition and sends one Disable, never two.
take_requests();
slint_testing::send_mouse_click(&instance, 210., 40.);
assert!(!instance.get_input_focused());
assert_eq!(instance.get_cancel_count(), 1);
assert!(matches!(take_requests().as_slice(), [InputMethodRequest::Disable]));

// Platform composition arriving without focus is ignored.
inner.process_key_input(InternalKeyEvent {
    event_type: KeyEventType::UpdateComposition,
    preedit_text: "unfocused".into(),
    ..Default::default()
});
assert_eq!(instance.get_preedit_count(), 2);

slint_testing::send_mouse_click(&instance, 40., 40.);
assert!(matches!(take_requests().as_slice(), [InputMethodRequest::Enable(_)]));
instance.set_input_enabled(false);
slint_testing::mock_elapsed_time(1);
assert!(matches!(take_requests().as_slice(), [InputMethodRequest::Disable]));
instance.set_input_enabled(true);
slint_testing::mock_elapsed_time(1);
assert!(matches!(take_requests().as_slice(), [InputMethodRequest::Enable(_)]));

// Commit remains associated with the generation submitted to the platform.
let mut commit = InternalKeyEvent { event_type: KeyEventType::CommitComposition, ..Default::default() };
let mut committed_key = KeyEvent::default();
committed_key.text = "界".into();
commit.key_event = committed_key;
inner.process_key_input(commit);
assert_eq!(instance.get_commit_count(), 1);
assert_eq!(instance.get_event_generation(), 3);
```
*/
